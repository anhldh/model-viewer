{
  "name": "@anhldh/model-viewer",
  "version": "0.2.2",
  "description": "Fork of @google/model-viewer with custom LOD and animation pointer support",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/model-viewer.min.js",
  "module": "lib/model-viewer.js",
  "type": "module",
  "files": [
    "src",
    "lib",
    "dist"
  ],
  "typings": "lib/model-viewer.d.ts",
  "types": "lib/model-viewer.d.ts",
  "exports": {
    ".": {
      "types": "./lib/model-viewer.d.ts",
      "import": "./lib/model-viewer.js",
      "default": "./dist/model-viewer.min.js"
    },
    "./react": {
      "types": "./lib/react.d.ts",
      "import": "./lib/react.js",
      "default": "./lib/react.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rm -rf ./lib ./dist",
    "build": "npm run build:tsc && npm run build:rollup",
    "build:dev": "npm run build:tsc && npm run build:rollup:dev",
    "build:tsc": "tsc --incremental",
    "build:rollup": "rollup -c --environment NODE_ENV:production",
    "build:rollup:dev": "rollup -c --environment NODE_ENV:development",
    "prepublishOnly": "npm run build",
    "watch:tsc": "tsc -w --incremental",
    "watch:rollup": "rollup -c -w --environment NODE_ENV:development",
    "dev": "npm-run-all --parallel watch:tsc watch:rollup"
  },
  "keywords": [
    "model-viewer",
    "gltf",
    "3d",
    "webxr"
  ],
  "dependencies": {
    "@anhldh/gltf-lod-loader": "^0.0.4",
    "@monogrid/gainmap-js": "^3.1.0",
    "lit": "^3.2.1"
  },
  "peerDependencies": {
    "@types/react": ">=18.0.0",
    "react": ">=18.0.0",
    "three": ">=0.170.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.2",
    "@rollup/plugin-swc": "^0.4.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@swc/core": "^1.11.8",
    "@types/react": "^18.3.29",
    "@types/three": ">=0.170.0",
    "npm-run-all": "^4.1.5",
    "rollup": "^4.59.0",
    "rollup-plugin-cleanup": "^3.2.1",
    "rollup-plugin-dts": "^6.1.1",
    "three": ">=0.170.0",
    "typescript": "5.8.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anhldh/model-viewer"
  },
  "homepage": "https://github.com/anhldh/model-viewer#readme",
  "bugs": {
    "url": "https://github.com/anhldh/model-viewer/issues"
  }
}
